# NeuralKB 环境变量配置
# 复制此文件为 .env 并填入真实值

# LLM API
RAG_LLM_API_KEY=your-api-key-here
RAG_LLM_URL=https://ai.gitee.com/v1
RAG_LLM_MODEL=Qwen3-235B-A22B

# JWT 认证
RAG_JWT_SECRET=change-me-in-production

# ── MinerU PDF 解析 ──────────────────────────────────────
# 运行模式: local=本地DL模型 | api=MinerU 云端 API (mineru.net)
RAG_MINERU_MODE=api
# API 模式下的 token（从 https://mineru.net/apiManage/token 获取）
RAG_MINERU_API_TOKEN=eyJ0eXBlIjoiSldUIiwiYWxnIjoiSFM1MTIifQ.eyJqdGkiOiIyNTcwMDc0NiIsInJvbCI6IlJPTEVfUkVHSVNURVIiLCJpc3MiOiJPcGVuWExhYiIsImlhdCI6MTc4MjU4NzYyMSwiY2xpZW50SWQiOiJsa3pkeDU3bnZ5MjJqa3BxOXgydyIsInBob25lIjoiMTc3NzAyNTQwNjkiLCJvcGVuSWQiOm51bGwsInV1aWQiOiI2ZDdlOGViMy0wZWIyLTQ2MDktOTQ0Yi0xMjU3YzMxZTkyOGQiLCJlbWFpbCI6IiIsImV4cCI6MTc5MDM2MzYyMX0.e-Endnmvro1d9dzwMhj1GXWOP8rrpCYDQhqLdApO21ZGXxlmZL5Kt4uXlfaDYR_sTrj8NF8njOONind_U2Z2qw
# API 模式下的模型版本: pipeline / vlm(推荐) / MinerU-HTML
RAG_MINERU_MODEL_VERSION=vlm

