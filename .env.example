# NeuralKB 环境变量配置
# 复制此文件为 .env 并填入真实值

# LLM API
RAG_LLM_API_KEY=your-api-key-here
RAG_LLM_URL=https://ai.gitee.com/v1
RAG_LLM_MODEL=Qwen3-235B-A22B

# JWT 认证
RAG_JWT_SECRET=change-me-in-production

# 可选配置
# RAG_LLM_TEMPERATURE=0.3
# RAG_LLM_MAX_TOKENS=2048
# RAG_TOP_K=15
# RAG_ALPHA=0.5
# RAG_MODEL_DIR=./models/bge-m3
# RAG_CHROMA_DIR=./chroma_db
# RAG_DB_PATH=./data/rag.db
